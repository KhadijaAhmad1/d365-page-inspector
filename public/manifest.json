{
  "manifest_version": 3,
  "name": "D365 Page Inspector",
  "short_name": "D365 Inspector",
  "version": "1.0.0",
  "description": "Instantly capture environment, legal entity, form, and page context from Microsoft Dynamics 365 Finance & Operations to speed up support ticket reporting.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "scripting", "storage", "clipboardWrite"],
  "host_permissions": [
    "*://*.dynamics.com/*",
    "*://*.operations.dynamics.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.dynamics.com/*"],
      "js": ["src/content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  }
}
